<%= form_with model: @project, class: "max-w-150" do |form| %>
    <div class="flex flex-col m-2 p-2 outline">
        <div class="flex flex-col m-1 p-1 outline">
            <%= form.label :name %>
            <%= form.text_field :name, class: "w-full" %>
        </div>
        <div class="flex flex-col m-1 p-1 outline">
            <%= form.label :description %>
            <%= form.text_field :description, class: "w-full" %>
        </div>
        <%= form.submit "Create Project", class: "m-1 p-1 outline" %>
    </div>
<% end %>