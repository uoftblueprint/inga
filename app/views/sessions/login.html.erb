<div class="min-h-screen grid grid-cols-1 md:grid-cols-2">
  <%# Left panel — branding %>
  <div class="hidden md:flex flex-col justify-center bg-primary px-12 py-14">
    <div class="flex flex-col gap-3">
      <h1 class="text-3xl font-bold text-primary-content leading-snug">Inga Internals</h1>
      <p class="text-primary-content/70 text-base max-w-sm mt-1">
        Track projects, review field journals, and generate external reports — all in one place.
      </p>
    </div>
  </div>

  <%# Right panel — form %>
  <div class="flex flex-col justify-center items-center px-6 py-14 sm:px-10 bg-base-100">
    <div class="w-full max-w-sm">
      <div class="flex justify-center mb-9">
        <%= image_tag "inga-logo.svg", alt: "Inga Foundation", class: "h-16 w-auto" %>
      </div>

      <div class="mb-8">
        <h2 class="text-3xl font-bold text-base-content">Welcome back</h2>
        <p class="text-base-content/50 text-sm mt-1">Sign in to your account to continue.</p>
      </div>

      <%= form_with url: login_path, local: true do |form| %>
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-base-content">Username</label>
            <%= form.text_field :username, required: true,
                  class: "input input-bordered w-full focus:input-primary",
                  placeholder: "Enter your username",
                  autocomplete: "username" %>
          </div>

          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-base-content">Password</label>
            <%= form.password_field :password, required: true,
                  class: "input input-bordered w-full focus:input-primary",
                  placeholder: "Enter your password",
                  autocomplete: "current-password" %>
          </div>

          <div class="mt-2">
            <%= form.submit "Sign in", class: "btn btn-primary w-full" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
