<div class="mx-8 my-10">
  <div class="flex items-center justify-between mb-5">
    <h1 class="text-4xl font-bold"><%= t(".title") %></h1>
  </div>
  <%= render ContentCardComponent.new do %>
    <div class="w-full max-w-2xl mx-auto space-y-6">
      <div class="card bg-base-100 border border-base-300 shadow-sm rounded-xl">
        <div class="card-body">
          <%= form_with url: filter_reports_path, method: :get, local: true, class: "space-y-4" do %>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= label_tag :start_date, t(".start_date"), class: "label font-semibold text-base-content" %>
                <%= date_field_tag :start_date, params[:start_date], class: "input w-full", autocomplete: "off", onchange: "this.form.requestSubmit()" %>
              </div>
              <div>
                <%= label_tag :end_date, t(".end_date"), class: "label font-semibold text-base-content" %>
                <%= date_field_tag :end_date, params[:end_date], class: "input w-full", autocomplete: "off", onchange: "this.form.requestSubmit()" %>
              </div>
            </div>

            <% if @projects&.any? %>
              <div>
                <%= label_tag nil, t(".projects"), class: "label font-semibold text-base-content" %>
                <div class="grid gap-2">
                  <% @projects.each do |project| %>
                    <label class="flex items-center gap-2 cursor-pointer">
                      <%= check_box_tag "project_ids[]", project.id,
                                        @selected_project_ids&.include?(project.id),
                                        class: "checkbox",
                                        onchange: "this.form.requestSubmit()" %>
                      <span><%= project.name %></span>
                    </label>
                  <% end %>
                </div>
              </div>

              <% if @subprojects&.any? %>
                <div>
                  <%= label_tag nil, t(".subprojects"), class: "label font-semibold text-base-content" %>
                  <div class="grid gap-2">
                    <% @subprojects.each do |subproject| %>
                      <label class="flex items-center gap-2 cursor-pointer">
                        <%= check_box_tag "subproject_ids[]", subproject.id,
                                          @selected_subproject_ids&.include?(subproject.id),
                                          class: "checkbox",
                                          onchange: "this.form.requestSubmit()" %>
                        <span><%= subproject.name %></span>
                      </label>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>

      <% if @selected_subproject_ids&.any? %>
        <div class="flex justify-end">
          <%= form_with url: reports_path, method: :post do %>
            <%= hidden_field_tag :start_date, params[:start_date] %>
            <%= hidden_field_tag :end_date, params[:end_date] %>
            <% @selected_subproject_ids.each do |id| %>
              <%= hidden_field_tag "subproject_ids[]", id %>
            <% end %>
            <%= submit_tag t(".generate"), class: "btn bg-success text-white border-success hover:bg-success/90" %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
