<section class="mx-2 my-4 sm:mx-8 sm:my-10">
  <% if logged_in? && !@report.active? %>
    <div class="mb-5 sm:mb-6">
      <div class="rounded-xl border border-error/30 bg-error/10 px-4 py-3 sm:px-5 sm:py-4">
        <p class="text-sm font-semibold text-error"><%= t(".inactive_warning_title") %></p>
        <p class="mt-1 text-sm text-error/90"><%= t(".inactive_warning_description") %></p>
      </div>
    </div>
  <% end %>

  <div class="mb-5 sm:mb-6">
    <div class="rounded-xl border border-primary/20 bg-primary/5 px-4 py-3 sm:px-5 sm:py-4">
      <%= image_tag "inga-logo.svg", alt: "Inga Foundation", class: "h-10 w-auto sm:h-14" %>

      <div class="mt-3 flex flex-col gap-0.5">
        <h1 class="text-3xl sm:text-4xl font-bold leading-tight">
          <%= t(".title", start_date: l(@report.start_date), end_date: l(@report.end_date)) %>
        </h1>
      </div>
    </div>
  </div>

  <div class="ui-enter-item border-y border-base-300 py-5" style="--ui-enter-delay: 60ms;">
    <section>
      <div class="mb-4">
        <h2 class="text-2xl font-bold text-primary"><%= t(".displayed_statistics") %></h2>
        <p class="text-sm text-base-content/70 mt-1"><%= t(".displayed_statistics_description") %></p>
      </div>

      <% if @report.aggregated_data.any? %>
        <%= render Reports::MarqueeComponent.new do |marquee| %>
          <% @report.aggregated_data.each do |aggregated_datum| %>
            <% marquee.with_slide do %>
              <%= render Reports::AggregatedDatumCardComponent.new(aggregated_datum: aggregated_datum) %>
            <% end %>
          <% end %>
        <% end %>
      <% else %>
        <p class="text-sm text-base-content/70"><%= t(".empty_statistics") %></p>
      <% end %>
    </section>
  </div>

  <div class="ui-enter-item mt-5 border-b border-base-300 pb-5" style="--ui-enter-delay: 110ms;">
    <section>
      <div class="mb-4">
        <h2 class="text-2xl font-bold text-primary"><%= t(".displayed_journals") %></h2>
        <p class="text-sm text-base-content/70 mt-1"><%= t(".displayed_journals_description") %></p>
      </div>

      <% if @report.journals.any? %>
        <div class="flex flex-col gap-3">
          <% @report.journals.each_with_index do |journal, idx| %>
            <div class="ui-enter-item" style="--ui-enter-delay: <%= 140 + (idx * 35) %>ms;">
              <%= render Reports::JournalCardComponent.new(journal: journal) %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-base-content/70"><%= t(".empty_journals") %></p>
      <% end %>
    </section>
  </div>

  <div class="ui-enter-item mt-5" style="--ui-enter-delay: 160ms;">
    <%= render Reports::ThankYouCardComponent.new %>
  </div>
</section>
