<section class="mx-8 my-10" data-controller="report-editor">
  <%= form_with url: report_path(@report), method: :patch, local: true do %>
    <div class="flex flex-col gap-4">

      <div class="flex flex-row justify-between items-start">
        <h1 class="text-4xl font-bold"><%= t(".title") %></h1>
        <%= submit_tag t(".save"), class: "btn bg-success text-white border-success hover:bg-success/90" %>
      </div>

      <%= render ContentCardComponent.new do %>
        <div class="flex items-center justify-between mb-4">
          <h1 class="text-2xl font-bold"><%= t(".aggregated_data") %></h1>
          <button type="button" class="btn btn-sm btn-primary gap-2" data-action="report-editor#addAggregatedDatum">
            <%= render IconComponent.new(icon: "add", size: :sm) %>
            <%= t(".add_aggregated_datum") %>
          </button>
        </div>

        <div class="flex flex-wrap gap-4 justify-center" data-report-editor-target="aggregatedDataList">
          <% @report.aggregated_data.each do |aggregated_datum| %>
            <div class="relative w-48" data-report-editor-target="aggregatedDatumCard">
              <%= hidden_field_tag "retained_aggregated_datum_ids[]", aggregated_datum.id %>
              <button
                  type="button"
                  class="btn btn-xs btn-outline btn-square absolute right-1 top-1 z-10 shadow-none border-white text-white hover:bg-white hover:text-black"
                  data-action="report-editor#removeAggregatedDatum"
                  aria-label="<%= t(".remove") %>">
                  <%= render IconComponent.new(icon: "close", size: :xs) %>
              </button>
              <%= render Reports::AggregatedDatumCardComponent.new(aggregated_datum: aggregated_datum, static: true) %>
            </div>
          <% end %>
        </div>

        <template data-report-editor-target="aggregatedDatumTemplate">
          <div class="relative w-48" data-report-editor-target="newAggregatedDatumCard">
            <button type="button" class="btn btn-xs btn-outline btn-square absolute right-1 top-1 z-10 shadow-none border-white text-white hover:bg-white hover:text-black" data-action="report-editor#removeNewAggregatedDatum" aria-label="<%= t(".remove") %>">
              <%= render IconComponent.new(icon: "close", size: :xs) %>
            </button>
            <div class="border rounded-md px-4 py-4 w-full text-left flex flex-col bg-gray-900 text-white">
              <input
                  type="number"
                  step="0.01"
                  name="new_aggregated_data[__INDEX__][value]"
                  required
                  placeholder="0"
                  class="text-4xl font-bold bg-transparent border-none outline-none w-full text-white placeholder-white/40 p-0 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                  autocomplete="off">
              <input
                  type="text"
                  name="new_aggregated_data[__INDEX__][additional_text]"
                  placeholder="<%= t(".content") %>"
                  required
                  class="text-lg mt-2 bg-transparent border-none outline-none w-full text-white placeholder-white/40 p-0"
                  autocomplete="off">
            </div>
          </div>
        </template>
      <% end %>

      <%= render ContentCardComponent.new do %>
        <h1 class="text-2xl font-bold mb-4"><%= t(".selected_journals") %></h1>

        <button
            type="button"
            class="btn btn-primary w-full gap-2 mb-4"
            data-action="report-editor#openJournalModal">
          <%= render IconComponent.new(icon: "add", size: :sm) %>
          <%= t(".add_journal") %>
        </button>

        <div class="flex flex-col gap-3" data-report-editor-target="selectedJournalsList">
          <% @selected_journals.each do |journal| %>
            <div class="relative" data-journal-id="<%= journal.id %>">
              <%= hidden_field_tag "journal_ids[]", journal.id %>
              <button
                  type="button"
                  class="btn btn-sm btn-outline btn-error absolute right-2 top-2 z-10 shadow-none"
                  data-action="report-editor#removeJournal"
                  aria-label="<%= t(".remove") %>">
                  <%= t(".remove") %>
              </button>
              <%= render Reports::JournalCardComponent.new(journal: journal) %>
            </div>
          <% end %>
        </div>

        <p class="text-sm text-center text-base-content/70 mt-2 hidden" data-report-editor-target="emptySelectedJournals">
        <%= t(".empty_journals") %>
        </p>
      <% end %>

    </div>

    <% @available_journals.each do |journal| %>
      <template data-report-editor-target="journalTemplate" data-journal-id="<%= journal.id %>">
        <div class="relative" data-journal-id="<%= journal.id %>">
          <%= hidden_field_tag "journal_ids[]", journal.id %>
          <button
              type="button"
              class="btn btn-xs btn-error btn-circle absolute right-2 top-2 z-10"
              data-action="report-editor#removeJournal"
              aria-label="<%= t(".remove") %>">
              <%= t(".remove") %>
          </button>
          <%= render Reports::JournalCardComponent.new(journal: journal) %>
        </div>
      </template>
    <% end %>
  <% end %>

  <%# journal picker modal — outside form so dialog close doesn't trigger form submit %>
  <dialog data-report-editor-target="journalModal" class="modal">
    <div class="modal-box max-w-4xl w-full">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-bold text-lg"><%= t(".available_journals") %></h3>
        <button
            type="button"
            class="btn btn-sm btn-circle btn-ghost"
            data-action="report-editor#closeJournalModal">
          <%= render IconComponent.new(icon: "close", size: :sm) %>
        </button>
      </div>

      <%= render Shared::IndexTableComponent.new(records: @available_journals, per_page: 8) do |table| %>
        <% table.column :title %>
        <% table.column :author, header: t(".author") do |journal| %>
          <%= journal.user.username %>
        <% end %>
        <% table.column :content, header: t(".content"), col_size: "minmax(0, 2fr)" do |journal| %>
          <%= truncate(journal.markdown_content.to_plain_text, length: 140) %>
        <% end %>
        <% table.column :actions, header: "", col_size: "auto" do |journal| %>
          <button
              type="button"
              class="btn btn-xs btn-primary"
              data-action="report-editor#addJournal"
              data-add-label="<%= t("reports.edit.add_journal") %>"
              data-added-label="<%= t("reports.edit.added_journal") %>"
              data-journal-id="<%= journal.id %>">
              <%= t("reports.edit.add_journal") %>
          </button>
        <% end %>
      <% end %>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
</section>
