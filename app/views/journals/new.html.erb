<div class="mx-8 my-10">
  <div class="flex items-center justify-between mb-5">
    <h1 class="text-4xl font-bold"><%= t(".title") %></h1>
  </div>

  <%= render ContentCardComponent.new do %>
    <%= render Projects::Subprojects::UnifiedFormComponent.new(
          projects: @projects,
          form_url: new_journal_path,
          selected_project_id: params[:project_id],
          selected_subproject_id: params[:subproject_id]
        ) do |component| %>
      <% component.with_form_body do %>
        <% project = Project.find_by(id: params[:project_id]) %>
        <% subproject = project&.subprojects&.find_by(id: params[:subproject_id]) %>
        <% if project && subproject %>
          <%= turbo_frame_tag "journal_new_form", src: new_project_subproject_journal_path(project, subproject) do %>
            <%= render Journals::EmptyFormComponent.new %>
          <% end %>
        <% else %>
          <%= render Journals::EmptyFormComponent.new %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
