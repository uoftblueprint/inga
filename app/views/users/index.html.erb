<div class="mx-8 my-10">
  <div class="flex items-center justify-between mb-4">
    <div class="flex flex-col gap-1">
      <h1 class="text-4xl font-bold"><%= t(".title") %></h1>
      <span class="text-lg text-base-content/60"><%= t(".subtitle") %></span>
    </div>
    <%= render ActionButtonComponent.new(to: new_user_path, icon: "add", colour: :primary, size: :large, turbo_stream: true) do %>
      <%= t(".actions.create") %>
    <% end %>
  </div>
  <%= render ContentCardComponent.new do %>
    <%= render Shared::IndexTableComponent.new(
          records: @users,
          record_path: ->(user) { user_path(user) }
        ) do |table| %>
      <% table.column :username %>
      <% table.column :roles do |user| %>
        <% role_colour_map = { "admin" => :primary, "reporter" => :secondary, "analyst" => :accent } %>
        <div class="flex gap-2 items-center">
          <% user.user_roles.each do |role| %>
            <% col = role_colour_map[role.role.to_s.downcase] %>
            <%= render BadgeComponent.new(text: role.role, colour: col) %>
          <% end %>
        </div>
      <% end %>
      <% table.column :actions, header: t("shared.index_table_component.actions"), col_size: "65px" do |user| %>
        <div class="flex flex-row gap-2 items-center justify-center">
          <%= render ActionButtonComponent.new(to: edit_user_path(user), icon: "edit", turbo_stream: true, colour: :primary) %>
          <%= render ActionButtonComponent.new(to: user_path(user), method: :delete, icon: "delete", colour: :error, confirm: t("users.destroy.confirm")) %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
