<div class="mx-auto mb-10 mt-40 w-4/5 max-w-[1450px]">
  <h1 class="text-3xl font-light mb-6">Users</h1>

  <%= render ContentCardComponent.new do %>
    <div class="flex items-center justify-between gap-4 mb-6">
      <div class="relative flex-1 max-w-md">
        <%= form_with url: users_path, method: :get, local: true do |f| %>
          <%= f.search_field :q, value: params[:q], placeholder: "Search User", class: "input input-bordered w-full rounded-full pl-10" %>
        <% end %>

        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>

      <%= link_to new_user_path, class: "btn rounded-lg shrink-0", style: "background-color: #84cc16; color: white; border: none;" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        New user      <% end %>
    </div>

    <div class="overflow-x-auto">
      <table class="table w-full">
        <thead style="background-color: #e8eaf0;">
          <tr>
            <th class="font-semibold text-left py-3">Username</th>
            <th class="font-semibold text-left py-3">Name</th>
            <th class="font-semibold text-left py-3">Role</th>
            <th class="font-semibold text-left py-3">View</th>
            <th class="font-semibold text-left py-3">Edit</th>
            <th class="font-semibold text-left py-3">Delete</th>
          </tr>
        </thead>

        <tbody>
          <% @users.each do |user| %>
            <tr class="border-b border-gray-200">
              <td class="py-4"><%= user.username %></td>
              <td class="py-4"><%= user.try(:name).presence || user.username %></td>

              <td class="py-4">
                <div class="flex gap-2">
                  <% user.user_roles.each do |role| %>
                    <% role_name = role.role.downcase %>
                    <% if role_name == "field_worker" || role_name.include?("field") %>
                      <span class="badge rounded-md px-3 py-1" style="background-color: #d4f5a8; color: #4a5a1f; border: none;">Field Worker</span>
                    <% elsif role_name == "admin" %>
                      <span class="badge rounded-md px-3 py-1" style="background-color: #a8c5e8; color: #1f3a5f; border: none;">Admin</span>
                    <% elsif role_name == "analyst" %>
                      <span class="badge rounded-md px-3 py-1" style="background-color: #fde68a; color: #78350f; border: none;">Analyst</span>
                    <% elsif role_name == "reporter" %>
                      <span class="badge rounded-md px-3 py-1" style="background-color: #d8b4fe; color: #581c87; border: none;">Reporter</span>
                    <% else %>
                      <span class="badge rounded-md px-3 py-1" style="background-color: #d1d5db; color: #374151; border: none;"><%= role.role.humanize %></span>
                    <% end %>
                  <% end %>
                </div>
              </td>

              <td class="py-4">
                <button class="btn btn-sm rounded-lg" style="background-color: #e5e7eb; color: #374151; border: none;">View User</button>
              </td>

              <td class="py-4">
                <%= link_to edit_user_path(user), class: "btn btn-sm btn-square rounded-lg", style: "background-color: #e5e7eb; border: none;" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-600" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                  </svg>
                <% end %>
              </td>

              <td class="py-4">
                <%= button_to user_path(user),
                              method: :delete,
                              form: { data: { turbo_confirm: "Are you sure you want to delete this user?" }, class: "inline-block" },
                              class: "btn btn-sm btn-square rounded-lg",
                              style: "background-color: #fecaca; border: none;" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-700" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                  </svg>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
