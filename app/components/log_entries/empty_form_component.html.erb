<div class="text-sm p-4 flex flex-col gap-4">
  <div class="grid gap-3">
    <% 4.times do %>
      <div class="rounded-lg border border-base-300 bg-base-200/50 px-3 py-3 sm:flex sm:items-center sm:px-3 sm:py-2">
        <div class="flex flex-col gap-2 sm:w-1/2 sm:flex-row sm:items-center sm:gap-0">
          <div class="text-base-content/40 font-medium sm:font-normal">-------</div>
        </div>

        <div class="mt-2 sm:mt-0 sm:w-1/2">
          <div class="input input-sm w-full opacity-40 cursor-not-allowed"></div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex justify-end gap-3">
    <button class="btn btn-ghost btn-sm" disabled>Cancel</button>
    <button class="btn btn-primary btn-sm" disabled>Create Log Entry</button>
  </div>
</div>
