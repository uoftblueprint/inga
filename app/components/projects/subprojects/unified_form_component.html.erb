<div class="w-full max-w-2xl mx-auto space-y-6">
  <div class="card bg-base-100 border border-base-300 shadow-sm rounded-xl">
    <div class="card-body">
      <%= form_with url: form_url, method: :get, local: true, class: "space-y-4" do %>
        <%= label_tag :project_id, t(".project_label"), class: "label" %>
        <%= select_tag :project_id,
                       options_from_collection_for_select(projects, :id, :name, selected_project_id),
                       prompt: t(".select_project_prompt"),
                       class: "select select-bordered w-full",
                       onchange: "this.form.requestSubmit()" %>

        <div class="min-h-[84px]">
          <% if selected_project_id.present? %>
            <% if selected_project.present? %>
              <%= label_tag :subproject_id, t(".subproject_label"), class: "label" %>
              <%= select_tag :subproject_id,
                             options_from_collection_for_select(selected_project.subprojects, :id, :name, selected_subproject_id),
                             prompt: t(".select_subproject_prompt"),
                             class: "select select-bordered w-full",
                             onchange: "this.form.requestSubmit()" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card bg-base-100 border border-base-300 shadow-sm rounded-xl min-h-60">
    <div class="card-body">
      <%= form_body %>
    </div>
  </div>
</div>
