<%= render ContentCardComponent.new do %>
  <section class="flex flex-col gap-6">
      <div class="flex flex-row justify-between">
        <label for="search" class="input rounded-full">
          <%= render IconComponent.new(icon: "search", size: :sm) %>
          <input id="search" type="search" name="q" required placeholder="Search project title" autocomplete="off">
        </label>
        <select class="select rounded-full w-min">
          <option disabled selected>Sort by</option>
        </select>
      </div>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(285px,1fr))] gap-6 w-full">
        <% projects.each do |project| %>
          <div class="card w-full flex flex-col justify-between gap-2 bg-base-100 border border-base-300 shadow-md p-4 rounded-xl">
            <div class="flex flex-col">
              <div class="flex justify-between items-center pb-2 mb-2">
                <h2 class="text-color-base-content text-lg font-semibold"><%= project.name %></h2>
                <div>
                  <%= render BadgeComponent.new(**project_badge_args(project), style: :soft, size: :sm) %>
                </div>
              </div>
              <div class="flex flex-col gap-0.5">
                <% project.subprojects.each do |subproject| %>
                  <%= render Home::SubprojectCardComponent.new(subproject: subproject) %>
                <% end %>
              </div>
            </div>
            <%= link_to "View project", project_path(project), class: "text-sm bg-base-300 rounded-md py-2 flex flex-row justify-center items-center" %>
          </div>
        <% end %>
      </div>
  </section>
<% end %>
