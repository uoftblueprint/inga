<div id="modal">
  <div class="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm flex items-center justify-center opacity-0 transition-opacity duration-200 ease-out"
       data-controller="modal"
       data-turbo-temporary
       data-action="turbo:submit-end->modal#close">

    <div data-modal-target="panel"
         class="card bg-base-100 border border-base-300 rounded-xl shadow-xl w-full max-w-xl p-6 max-h-[90vh] flex flex-col transition duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold"><%= title %></h2>
        <button type="button"
                class="btn btn-ghost btn-xs btn-circle text-base-content/40 hover:text-error"
                data-action="modal#close">
          ✕
        </button>
      </div>

      <%= render "shared/flash" %>

      <div class="mt-3 overflow-y-auto"> <%= content %> </div>
    </div>
  </div>
</div>
