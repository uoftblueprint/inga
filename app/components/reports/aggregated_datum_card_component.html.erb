<div class="carousel-item border rounded-md px-4 py-4 w-48 text-left flex flex-col flex-none bg-gray-900 text-white">
  <h3 class="text-4xl font-bold">
    <% if @aggregated_datum.value.present? %>
      <% value = @aggregated_datum.value %>
      <%= value.to_f % 1 == 0 ? value.to_i : value %>
    <% end %>
  </h3>
  <p class="text-lg mt-2"><%= @aggregated_datum.additional_text %></p>
</div>
